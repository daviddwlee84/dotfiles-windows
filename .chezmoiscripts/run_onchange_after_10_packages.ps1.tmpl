#Requires -Version 7
# run_onchange_after_10_packages.ps1 — install the toolset with scoop (CLI) +
# winget (GUI). Idempotent: only missing packages are installed. This script is
# the SINGLE SOURCE OF TRUTH for what gets installed; re-runs whenever the
# rendered content (i.e. any toggle below) changes.
#
# Toggles (from .chezmoi.toml.tmpl):
#   installCodingAgents  = {{ .installCodingAgents }}
#   installWindowsApps   = {{ .installWindowsApps }}
#   installUtilityApps   = {{ .installUtilityApps }}
#   installGamingApps    = {{ .installGamingApps }}
#   installExtraRuntimes = {{ .installExtraRuntimes }}
#   installMediaTools    = {{ .installMediaTools }}
#   installLlmTools      = {{ .installLlmTools }}
#   installTunnelTools   = {{ .installTunnelTools }}
#   installIacTools      = {{ .installIacTools }}
#   installHerdr         = {{ .installHerdr }}
#   installClink         = {{ .installClink }}
#   useChineseMirror     = {{ .useChineseMirror }}
#   managedMachine       = {{ .managedMachine }}

# Resilient by design: individual package failures are collected and reported at
# the end, never fatal — one bad manifest must not abort the rest of the install
# (nor the rest of `chezmoi apply`). Mirrors ansible allow-partial-failure.
$ErrorActionPreference = 'Continue'
if (Test-Path variable:PSNativeCommandUseErrorActionPreference) { $PSNativeCommandUseErrorActionPreference = $false }
$script:Failures = [System.Collections.Generic.List[string]]::new()

# UTF-8 console so winget's localized output isn't mojibake on zh-* Windows.
try { [Console]::OutputEncoding = [System.Text.UTF8Encoding]::new($false) } catch { $null = $_ }
{{ if .useChineseMirror }}
# China (GFW) mirrors for install-time package fetches.
$env:PIP_INDEX_URL = 'https://pypi.tuna.tsinghua.edu.cn/simple'
$env:UV_DEFAULT_INDEX = 'https://pypi.tuna.tsinghua.edu.cn/simple'
$env:npm_config_registry = 'https://registry.npmmirror.com'
$env:GOPROXY = 'https://goproxy.cn,direct'
$env:MISE_NODE_MIRROR_URL = 'https://npmmirror.com/mirrors/node/'
{{ end }}

function Info($m) { Write-Host "==> $m" -ForegroundColor Cyan }
function Have($n) { [bool](Get-Command $n -ErrorAction SilentlyContinue) }
function Register-Failure($what) { $script:Failures.Add($what); Write-Warning "FAILED (skipped): $what" }

# --- scoop -----------------------------------------------------------------
function Test-Admin {
    # $true when this pwsh is running elevated (member of the Administrators role).
    try {
        $id = [Security.Principal.WindowsIdentity]::GetCurrent()
        ([Security.Principal.WindowsPrincipal]$id).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)
    } catch { $false }
}

function Ensure-Scoop {
    if (-not (Have scoop)) {
        # get.scoop.sh returns install.ps1's text. Piping it to Invoke-Expression
        # works in a normal console, but an ELEVATED one is refused ("Running the
        # installer as administrator is disabled by default") unless -RunAsAdmin is
        # passed. Some dev boxes always open the shell as admin, so detect that and
        # forward the flag. We build a scriptblock from the fetched text so we can
        # pass args -- equivalent to `iex "& {$(irm get.scoop.sh)} -RunAsAdmin"`.
        $installer = [scriptblock]::Create((Invoke-RestMethod get.scoop.sh))
        if (Test-Admin) {
            Info 'scoop not found — installing (elevated console: passing -RunAsAdmin)'
            & $installer -RunAsAdmin
        } else {
            Info 'scoop not found — installing (user-scoped, no admin)'
            & $installer
        }
    }
    foreach ($b in 'main', 'extras', 'versions', 'nerd-fonts') {
        scoop bucket add $b *> $null
    }
}

function Get-ScoopInstalled {
    try { return @((scoop export | ConvertFrom-Json).apps.name) } catch { return @() }
}

function Scoop-Install([string[]]$apps) {
    if (-not $apps) { return }
    # Wrap in @() so a lone survivor stays an array. Without it PowerShell
    # unwraps a single match to a bare string, and `scoop install @missing`
    # then splats it one CHARACTER per arg => "Couldn't find manifest for 'm'"
    # when only "mise" was missing.
    $missing = @($apps | Where-Object { ($_ -split '/')[-1] -notin (Get-ScoopInstalled) })
    if (-not $missing) { Info 'scoop: all requested tools already present'; return }
    Info "scoop install: $($missing -join ', ')"
    try { scoop install @missing } catch { Write-Warning "scoop batch error: $_" }
    # Anything still absent after the batch = failed (scoop keeps going past a bad one).
    $after = Get-ScoopInstalled
    foreach ($app in $missing) {
        $name = ($app -split '/')[-1]
        if ($name -notin $after) { Register-Failure "scoop:$name" }
    }
}

# --- winget ----------------------------------------------------------------
function Winget-Install([string]$id) {
    if (-not (Have winget)) { Register-Failure "winget:$id (winget unavailable)"; return }
    winget list --id $id -e --accept-source-agreements *> $null
    if ($LASTEXITCODE -eq 0) { return }   # already installed
    Info "winget install $id"
    winget install --id $id -e --silent --scope user `
        --accept-source-agreements --accept-package-agreements 2>&1 | Out-Host
    if ($LASTEXITCODE -ne 0) {
        # some packages don't support --scope user; retry machine scope.
        winget install --id $id -e --silent `
            --accept-source-agreements --accept-package-agreements 2>&1 | Out-Host
    }
    if ($LASTEXITCODE -ne 0) { Register-Failure "winget:$id" }
}

# Microsoft Store packages (installed by Store product id via the msstore
# source) — used for apps with no community winget manifest, e.g. Raycast and the
# official ChatGPT desktop app. msstore ignores --scope, so we don't pass it.
function Winget-InstallStore([string]$id) {
    if (-not (Have winget)) { Register-Failure "msstore:$id (winget unavailable)"; return }
    winget list --id $id -e --accept-source-agreements *> $null
    if ($LASTEXITCODE -eq 0) { return }   # already installed
    Info "winget (msstore) install $id"
    winget install --id $id -e --source msstore --silent `
        --accept-source-agreements --accept-package-agreements 2>&1 | Out-Host
    if ($LASTEXITCODE -ne 0) { Register-Failure "msstore:$id" }
}

# --- npm CLI agents --------------------------------------------------------
function Npm-InstallGlobal([string[]]$pkgs) {
    if (-not (Have npm)) { foreach ($p in $pkgs) { Register-Failure "npm:$p (npm unavailable)" }; return }
    foreach ($p in $pkgs) {
        Info "npm i -g $p"
        npm install -g $p 2>&1 | Out-Host
        if ($LASTEXITCODE -ne 0) { Register-Failure "npm:$p" }
    }
}

# --- herdr (native Windows terminal multiplexer, preview beta) --------------
# No scoop/winget/npm manifest — installs via herdr.dev's irm|iex bootstrap
# (same shape as Ensure-Scoop). Windows builds are preview-only; the bin junction
# is %LOCALAPPDATA%\Programs\Herdr\bin (added to PATH in profile.d/00_env.ps1).
function Install-Herdr {
    $herdrBin = Join-Path $env:LOCALAPPDATA 'Programs\Herdr\bin\herdr.exe'
    if ((Have herdr) -or (Test-Path -LiteralPath $herdrBin)) { Info 'herdr already installed'; return }
    Info 'installing herdr (preview) via herdr.dev/install.ps1'
    try {
        $env:HERDR_CHANNEL = 'preview'   # Windows builds are preview-only
        $installer = [scriptblock]::Create((Invoke-RestMethod https://herdr.dev/install.ps1))
        & $installer
        if (-not (Test-Path -LiteralPath $herdrBin)) { Register-Failure 'herdr' }
    } catch {
        Write-Warning "herdr install error: $_"
        Register-Failure 'herdr'
    }
}

# ===========================================================================
Ensure-Scoop

# Core CLI toolset — the shell baseline, always installed.
Scoop-Install @(
    'git', 'gh', 'glab', '7zip', 'make', 'just',
    'starship', 'zoxide', 'fzf', 'fd', 'ripgrep', 'bat', 'eza', 'jq',
    'delta', 'lazygit', 'neovim', 'yazi', 'btop', 'television', 'tlrc',
    'uv', 'gnupg',
    # Runtimes are NATIVE via scoop, not mise: mise's activate/shims are
    # unreliable on Windows and it has no windows-arm64 bun build. node + bun
    # here; Python via uv (below); go/rust/ruby under Extra runtimes.
    # copilot-proxy needs bun/bunx.
    'nodejs-lts', 'bun',
    # LazyVim needs a C compiler for tree-sitter parsers (zig), the tree-sitter
    # CLI the nvim-treesitter `main` branch requires, and a clipboard provider so
    # `unnamedplus` yanks reach the Windows clipboard (win32yank).
    'zig', 'tree-sitter', 'win32yank'
)

# On Windows-on-ARM, scoop's neovim is amd64 (runs under x64 emulation) while
# zig installs arm64-native, so zig-built tree-sitter parsers are the wrong
# arch for nvim. Add an amd64 gcc that matches the emulated nvim.
if ([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture -eq 'Arm64') {
    Info 'ARM64 host: adding amd64 gcc for nvim-treesitter'
    Scoop-Install @('gcc')
}

# gh-dash: GitHub PR/issue dashboard TUI (`gh dash`). It's a gh extension, not a
# scoop package, so it needs gh to be authenticated -- this no-ops on a fresh
# machine until `gh auth login`. run_onchange only re-fires when this script
# changes, so after authenticating, install by hand (`gh extension install
# dlvhdr/gh-dash`) or force a reapply (`chezmoi state delete-bucket
# --bucket=entryState`). gh-notify / gh-select from the Unix repo are bash-only
# extensions and are intentionally skipped on Windows.
if (Have gh) {
    gh auth status *> $null
    if ($LASTEXITCODE -eq 0) {
        $ghExts = gh extension list 2>$null | Out-String
        if ($ghExts -notmatch 'dlvhdr/gh-dash') {
            Info 'gh extension install dlvhdr/gh-dash'
            gh extension install dlvhdr/gh-dash
            if ($LASTEXITCODE -ne 0) { Register-Failure 'gh-ext:gh-dash' }
        }
    } else {
        Info 'gh not authenticated -- skipping gh-dash (gh auth login, then reapply)'
    }
}

# node/bun come from scoop above (on ~/scoop/shims, reliably on PATH). We do NOT
# use mise here -- see the runtimes note in the core scoop list.

# Default Python, uv-managed. --default also creates unversioned python/python3
# (not just python3.x) in UV_PYTHON_BIN_DIR (~/.local/bin, on PATH via 00_env
# ahead of the Store's python.exe app-alias). On uv 0.8+ `--default` lives behind
# preview mode, so it must be paired with `--preview` (older uv just ignored it) —
# without it, current uv errors: "`--default` is only available in preview mode".
if (Have uv) {
    Info 'uv python install --default --preview'
    $env:UV_PYTHON_BIN_DIR = Join-Path $HOME '.local\bin'
    uv python install --default --preview 2>&1 | Out-Host
    if ($LASTEXITCODE -ne 0) { Register-Failure 'uv:python' }
}

# Make PSGallery usable non-interactively before Install-Module (NuGet provider
# + trust) so the fzf key bindings / audio cmdlets install reliably.
try {
    if (-not (Get-PackageProvider -Name NuGet -ListAvailable -ErrorAction SilentlyContinue)) {
        Install-PackageProvider -Name NuGet -Scope CurrentUser -Force -ErrorAction SilentlyContinue | Out-Null
    }
    if ((Get-PSRepository -Name PSGallery -ErrorAction SilentlyContinue).InstallationPolicy -ne 'Trusted') {
        Set-PSRepository -Name PSGallery -InstallationPolicy Trusted -ErrorAction SilentlyContinue
    }
} catch { Write-Warning "PSGallery prep failed (non-fatal): $_" }

# PSReadLine ships with pwsh; PSFzf powers the fzf key bindings in profile.d
# (Ctrl+t = files, Ctrl+r = fuzzy history search).
if (-not (Get-Module -ListAvailable -Name PSFzf)) {
    Info 'Install-Module PSFzf'
    Install-Module PSFzf -Scope CurrentUser -Force -AcceptLicense -ErrorAction SilentlyContinue
}
# AudioDeviceCmdlets: absolute volume + explicit mute for the sys* helpers.
if (-not (Get-Module -ListAvailable -Name AudioDeviceCmdlets)) {
    Info 'Install-Module AudioDeviceCmdlets'
    Install-Module AudioDeviceCmdlets -Scope CurrentUser -Force -AcceptLicense -ErrorAction SilentlyContinue
}

