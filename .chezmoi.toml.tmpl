# Windows dotfiles — chezmoi config template.
# Rendered once at `chezmoi init`; answers are stored in
# %USERPROFILE%\.config\chezmoi\chezmoi.toml and never re-asked.
#
# This repo targets **native Windows + PowerShell 7 (pwsh)** only. There is no
# OS branching: everything here assumes Windows. WSL/macOS/Linux are handled by
# the separate cross-platform dotfiles repo.

[data]
    # role picks coarse defaults; every toggle can still be overridden.
    {{- $role := promptChoiceOnce . "role" "Role: workstation (full desktop) or minimal (shell only)" (list "workstation" "minimal") "workstation" }}
    {{- $full := eq $role "workstation" }}
    role  = {{ $role | quote }}
    name  = {{ promptStringOnce . "name" "Your full name (git)" "Da-Wei Lee" | quote }}
    email = {{ promptStringOnce . "email" "Your git email" "daviddwlee84@gmail.com" | quote }}

    # --- feature toggles (role-defaulted) ---
    installCodingAgents  = {{ promptBoolOnce . "installCodingAgents" "Install coding agents (Claude Code, OpenCode, Codex, Copilot CLI, SpecStory)" $full }}
    installWindowsApps   = {{ promptBoolOnce . "installWindowsApps" "Install GUI apps via winget (VSCode, Cursor, Notepad++, Terminal, Alacritty, PowerToys, Raycast)" $full }}
    installUtilityApps   = {{ promptBoolOnce . "installUtilityApps" "Install utility apps via winget (CPU-Z, GPU-Z, TreeSize, VLC, Everything, ShareX, HWiNFO)" $full }}
    installGamingApps    = {{ promptBoolOnce . "installGamingApps" "Install gaming apps (Steam)" false }}
    installExtraRuntimes = {{ promptBoolOnce . "installExtraRuntimes" "Install extra runtimes (rust, go, ruby) beyond node/bun/uv" $full }}
    installMediaTools    = {{ promptBoolOnce . "installMediaTools" "Install media CLIs (ffmpeg, imagemagick)" false }}
    installLlmTools      = {{ promptBoolOnce . "installLlmTools" "Install local LLM tools (Ollama, LiteLLM)" false }}
    installTunnelTools   = {{ promptBoolOnce . "installTunnelTools" "Install tunnel tools (ngrok, cloudflared)" false }}
    installIacTools      = {{ promptBoolOnce . "installIacTools" "Install Infrastructure-as-Code tools (Azure CLI, Terraform, OpenTofu)" false }}
    installSshServer     = {{ promptBoolOnce . "installSshServer" "Install and enable the OpenSSH server / sshd (needs admin, opens inbound port 22)" false }}
    useChineseMirror     = {{ promptBoolOnce . "useChineseMirror" "Use China (GFW) mirrors for pip/npm/cargo/go/node" false }}
    managedMachine       = {{ promptBoolOnce . "managedMachine" "Managed or corporate machine (skip org-policy-blocked apps like Tailscale and Grammarly)" false }}
    backupMode           = {{ promptChoiceOnce . "backupMode" "Back up existing files before apply (smart|full|off)" (list "smart" "full" "off") "smart" | quote }}
    enableVimMode        = {{ promptBoolOnce . "enableVimMode" "Enable PSReadLine vi editing mode" true }}

# Run .ps1 scripts (.chezmoiscripts + modify_/create_) under PowerShell 7.
[interpreters.ps1]
    command = "pwsh"
    args = ["-NoProfile", "-NonInteractive"]

[diff]
    exclude = ["scripts"]

[status]
    exclude = ["scripts"]
